# Email backend: "gmail" (default) or "cloudflare"
EMAIL_BACKEND=gmail

# ---- Gmail backend ----
# Google service account JSON
GOOGLE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"...","client_email":"...","auth_uri":"...","token_uri":"...","auth_provider_x509_cert_url":"...","client_x509_cert_url":"..."}

# Gmail address that receives all domain emails (catch-all)
GMAIL_USER=admin@yourdomain.com

# ---- Cloudflare backend ----
# Your Cloudflare account ID
CF_ACCOUNT_ID=
# D1 database ID where the email worker stores messages
CF_D1_DATABASE_ID=
# API token with D1 read/write access
CF_API_TOKEN=

# ---- Shared ----
# Allowed domains (comma-separated)
ALLOWED_DOMAINS=opendots.me,kefine.store,bdss.club,chiffn.site,relegendabl.es

# API key for authentication (leave empty to disable)
API_KEY=your-secret-api-key-here
