# Gmail API credentials - Google service account JSON
GOOGLE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"...","client_email":"...","auth_uri":"...","token_uri":"...","auth_provider_x509_cert_url":"...","client_x509_cert_url":"..."}

# Gmail address that receives all domain emails (catch-all)
GMAIL_USER=admin@yourdomain.com

# Allowed domains (comma-separated)
ALLOWED_DOMAINS=yourdomain.com,yourdomain2.com

# API key for authentication
API_KEY=your-secret-api-key-here
